# Backend environment

# Core behavior
USE_MOCK_DATA=true
GRAPH_RECURSION_LIMIT=120
RUN_QUEUE_WAIT_SECONDS=90
CORS_ORIGINS=http://localhost:8080
CRON_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SYNTHESIS_MODEL=gpt-4o-mini

# Market/Fundamental/News providers
NEWS_API_KEY=
FUNDAMENTALS_API_KEY=
MARKET_DATA_API_KEY=
NEWS_API_BASE_URL=https://finnhub.io/api/v1
FUNDAMENTALS_API_BASE_URL=https://financialmodelingprep.com
MARKET_DATA_API_BASE_URL=https://api.marketstack.com/v1

# RAG (optional)
PINECONE_HOST=
PINECONE_API_KEY=
RAG_EMBED_MODEL=text-embedding-3-small

# Monitoring/observability
SENTRY_DSN=
MONITOR_WEBHOOK_URL=
