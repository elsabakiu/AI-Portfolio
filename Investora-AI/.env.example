# InvestoraAI Frontend Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env — it is in .gitignore

# ── Sentry (optional) ──────────────────────────────────────
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ── Google Analytics ───────────────────────────────────────
# Replace G-XXXXXXXXXX in index.html with your Measurement ID
# Get from: https://analytics.google.com → Admin → Data Streams → Web

# ── FastAPI Backend ────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
